# Copy to .env (gitignored) and fill in. Nothing auto-loads .env — pass it explicitly:
#   DATABASE_URL=... pnpm --filter @yokel/docketclock test
# The Regs.gov smoke self-loads this file via process.loadEnvFile.

# Postgres connection string for the observation log (local throwaway or CNPG-managed in-cluster).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/docketclock

# Regulations.gov v4 API key (api.regulations.gov / api.data.gov). Registered key = 1,000 req/hr;
# DEMO_KEY is ~30/hr. Used by the Regs.gov adapter's keyed fetch and `pnpm smoke:regs`.
REGS_API_KEY=

# Optional: override the Regs.gov v4 base (defaults to https://api.regulations.gov/v4).
# REGS_API_BASE=https://api.regulations.gov/v4

# LLM adjudicator for the chain-seam escalation (Slice 3). DORMANT by default — activation requires
# BOTH ADJUDICATOR=gemini AND a non-empty GEMINI_API_KEY; unset/empty either one => null:abstain
# (deterministic-only, safe). The credential is named for its provider (a key only works with Gemini);
# the provider-agnostic seam is the ADJUDICATOR selector + selectAdjudicator(), not the key name.
# ADJUDICATOR=gemini
# GEMINI_API_KEY=
# Optional: override the model (default gemini-2.5-flash) or the per-call timeout (ms, default 15000).
# GEMINI_MODEL=gemini-2.5-flash
# LLM_TIMEOUT_MS=15000
